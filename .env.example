# Copy to .env and fill in. Never commit the real .env.

# Pick ONE provider:
#   hf       -> local open model (no API key; enables Min-K% MIA)
#   deepseek -> DeepSeek chat API (embeddings run locally, no 2nd API)
#   openai   -> GPT-4o (closest to the paper's closed-model numbers)
UNLEARN_PROVIDER=deepseek

# Only the key for your chosen provider is needed:
DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Optional overrides (provider-appropriate defaults are auto-selected):
# UNLEARN_TARGET_MODEL=deepseek-chat
# UNLEARN_HELPER_MODEL=deepseek-chat
# UNLEARN_JUDGE_MODEL=deepseek-chat
# UNLEARN_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
